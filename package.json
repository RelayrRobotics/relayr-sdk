{
  "name": "@relayrrobotics/sdk",
  "version": "0.1.2",
  "description": "Relayr SDK — connect your robot, execute paid actions after USDG Settlement Splitter pay, report proof",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RelayrRobotics/relayr-sdk.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "demo": "bun --env-file=.env examples/demo-bridge.ts",
    "demo:webhook": "bun --env-file=.env examples/webhook-server.ts",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "relayr",
    "robotics",
    "payments"
  ],
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.8.3"
  }
}
