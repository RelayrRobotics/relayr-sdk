# Copy to .env and fill in after rotating a key in Operator Console → Settings
RELAYR_API_KEY=rl_your_key_here
RELAYR_API_URL=https://api.relayr.tech

# Optional robot filter for poll mode
# RELAYR_ROBOT_ID=rbt_your_robot

# Poll interval for listen() (ms). Default 2000. Prefer webhooks in production.
# RELAYR_POLL_MS=2000

# Webhook HMAC secret (Settings → reveal webhook secret). Required for production webhook handlers.
# RELAYR_WEBHOOK_SECRET=whsec_...
